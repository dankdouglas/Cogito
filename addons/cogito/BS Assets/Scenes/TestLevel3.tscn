[node name="ReadableComponent" parent="Hint_01" instance=ExtResource("33_qn7h4")]
interact_sound = ExtResource("34_b071e")
readable_title = "Objective"
readable_content = "This is the main pump facility where fuel and oxygen are pumped into the reactor. The area is hazardous: fuel leaks, scorching gas venting from pipes, infected roaming the halls, and deep chasms. Your objective: Navigate to the control room, illuminated by red lights, to restore the flow of fuel and oxygen. Then, proceed to the security room, marked by blue lights, to deactivate the lockdown and secure your escape.
(this level is still work in progress)"
interaction_text = "Read hint"


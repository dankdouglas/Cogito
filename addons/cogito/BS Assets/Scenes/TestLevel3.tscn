[node name="ReadableComponent" parent="Hint_03" instance=ExtResource("33_qn7h4")]
interact_sound = ExtResource("34_b071e")
readable_title = "Infected"
readable_content = "\"The infected roam the facility, some mindlessly circling while others patrol. They aren’t highly perceptive but will spot you if you cross their path, chasing to attack and spread their infection. They take five shots to kill, so consider using stealth to conserve your supplies—but sometimes, a well-placed shot is the best solution.\""
interaction_text = "Read hint"

